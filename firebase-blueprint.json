{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users and mechanics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["id", "username", "role", "createdAt"]
    },
    "Wiring": {
      "title": "Wiring",
      "description": "Wiring information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicle_id": { "type": "string" },
        "system": { "type": "string" },
        "component": { "type": "string" },
        "wire_color": { "type": "string" },
        "voltage": { "type": "string" },
        "source": { "type": "string" },
        "destination": { "type": "string" },
        "location": { "type": "string" },
        "confidence": { "type": "number" }
      },
      "required": ["id", "vehicle_id", "component"]
    },
    "Fuse": {
      "title": "Fuse",
      "description": "Fuse information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicle_id": { "type": "string" },
        "fuse_number": { "type": "string" },
        "rating_amp": { "type": "number" },
        "component": { "type": "string" },
        "location": { "type": "string" },
        "confidence": { "type": "number" }
      },
      "required": ["id", "vehicle_id", "fuse_number"]
    },
    "Relay": {
      "title": "Relay",
      "description": "Relay information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicle_id": { "type": "string" },
        "name": { "type": "string" },
        "input": { "type": "string" },
        "output": { "type": "string" },
        "location": { "type": "string" },
        "confidence": { "type": "number" }
      },
      "required": ["id", "vehicle_id", "name"]
    },
    "Cache": {
      "title": "Cache",
      "description": "System cache",
      "type": "object",
      "properties": {
        "query": { "type": "string" },
        "results": { "type": "object" },
        "timestamp": { "type": "number" }
      },
      "required": ["query", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/logs/{logId}": {
      "schema": { "$ref": "#/entities/Log" },
      "description": "System activity logs"
    },
    "/wiring/{wiringId}": {
      "schema": { "$ref": "#/entities/Wiring" },
      "description": "Wiring info"
    },
    "/fuses/{fuseId}": {
      "schema": { "$ref": "#/entities/Fuse" },
      "description": "Fuse info"
    },
    "/relays/{relayId}": {
      "schema": { "$ref": "#/entities/Relay" },
      "description": "Relay info"
    },
    "/cache/{query}": {
      "schema": { "$ref": "#/entities/Cache" },
      "description": "System cache"
    }
  }
}
