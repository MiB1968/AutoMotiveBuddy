{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "System operative profile with role and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "super_admin"] },
        "status": { "type": "string", "enum": ["active", "disabled", "pending"] },
        "subscription": {
          "type": "object",
          "properties": {
            "plan": { "type": "string" },
            "startDate": { "type": "string", "format": "date-time" },
            "endDate": { "type": "string", "format": "date-time" },
            "active": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/logs/{logId}": {
      "schema": "object",
      "description": "System audit logs"
    },
    "/saved_items/{itemId}": {
      "schema": "object",
      "description": "User saved diagnostics"
    }
  }
}
