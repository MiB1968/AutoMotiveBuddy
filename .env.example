# Neural Bridge API URL (Leave empty to use the built-in AI Studio backend)
VITE_API_URL=

# Firebase Admin SDK configuration (JSON string from Service Account)
FIREBASE_CONFIG=

# JWT Secret for signing local tokens (e.g. neuro-pass-xyz-123)
JWT_SECRET=

# Railway Project ID
RAILWAY_PROJECT_ID=
VITE_RAILWAY_PROJECT_ID=

# Gemini AI Platform Matrix Keys
GEMINI_API_KEY=
GEMINI_API_KEY_FALLBACK=
GEMINI_API_KEY_SECONDARY=
