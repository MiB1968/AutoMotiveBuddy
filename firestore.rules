rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    // Verify an admin via an external document or specific email
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'rubenlleg12@gmail.com')
      ); 
    }

    // User Entities Schema Validation
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'username', 'role', 'createdAt']) &&
             data.id is string && data.id.size() <= 64 &&
             data.username is string && data.username.size() <= 64 &&
             data.role in ['admin', 'member'] &&
             data.createdAt is string &&
             ( !('fullName' in data) || (data.fullName is string && data.fullName.size() <= 128) ) &&
             ( !('email' in data) || (data.email is string && data.email.size() <= 128) ) &&
             ( !('status' in data) || (data.status in ['pending', 'approved', 'rejected']) ) &&
             ( !('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 2048) );
    }

    // Users Collection
    match /users/{userId} {
      // Must be an admin or the owner
      allow get: if isSignedIn() && isValidId(userId) && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && (resource.data.id == request.auth.uid || isAdmin());
      
      // Allow user to create their own record
      allow create: if isVerified() && 
                       isValidId(userId) && 
                       userId == request.auth.uid &&
                       isValidUser(incoming()) &&
                       incoming().id == request.auth.uid &&
                       (incoming().role == 'member' || request.auth.token.email == 'rubenlleg12@gmail.com'); // Can't self-assign admin unless hardcoded

      // Allow users to update their own record, but not their role. Admin can update everything.
      allow update: if isVerified() && isValidId(userId) && isValidUser(incoming()) && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          incoming().id == existing().id &&
          incoming().role == existing().role &&
          incoming().diff(existing()).affectedKeys().hasOnly(['username', 'fullName', 'avatarUrl'])
        )
      );

      allow delete: if isAdmin();
    }

    // Logs Collection schema validation
    function isValidLog(data) {
       return data.keys().hasAll(['id', 'userId', 'username', 'action', 'details', 'timestamp']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 64 &&
             data.username is string && data.username.size() <= 64 &&
             data.action is string && data.action.size() <= 128 &&
             data.details is string && data.details.size() <= 500 &&
             data.timestamp is string; // Using string to align with the blueprint
    }

    // Logs Collection
    match /logs/{logId} {
      allow read: if isAdmin();
      
      // Any signed in user can create a log, but it must be their own log
      allow create: if isVerified() && 
                       isValidId(logId) && 
                       isValidLog(incoming()) &&
                       incoming().userId == request.auth.uid;
                       
      // Logs are immutable
      allow update, delete: if false;
    }
  }
}
